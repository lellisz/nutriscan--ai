SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:3000

# Groq - tier gratuito: 14.400 req/dia, sem cartão (recomendado)
# Obter chave: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini - tier gratuito: 1.500 req/dia (requer billing no BR)
# Obter chave: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic - fallback pago (Haiku, muito mais barato que Opus)
ANTHROPIC_API_KEY=

# Ollama (local AI) - opcional, para desenvolvimento local sem custos
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava

# AI_PROVIDER options:
#   "groq_with_fallback"      → Groq grátis + fallback Anthropic Haiku (padrão recomendado)
#   "groq"                    → Apenas Groq (grátis até 14.400 req/dia)
#   "gemini_with_fallback"    → Gemini + fallback Anthropic Haiku
#   "gemini"                  → Apenas Gemini
#   "anthropic"               → Apenas Anthropic Haiku
#   "anthropic_with_fallback" → Anthropic Haiku + fallback Ollama (legado)
#   "ollama"                  → Apenas Ollama local
AI_PROVIDER=groq_with_fallback